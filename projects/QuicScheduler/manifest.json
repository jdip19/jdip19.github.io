{
  "manifest_version": 3,
  "name": "QuicScheduler",
  "version": "3.0",
  "description": "Auto-fill social media posts from Google Sheets",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [
    "https://sheets.googleapis.com/*",
    "https://docs.google.com/*",
    "https://spreadsheets.google.com/*",
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Post Scheduler"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
